{
  "$schema": "vscode://schemas/color-theme",
  "name": "Hespyrn Nocturne",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "focusBorder": "#375fad",
    "foreground": "#bcbec4",
    "descriptionForeground": "#9da0a8",
    "errorForeground": "#f75464",
    "selection.background": "#214283",
